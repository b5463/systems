{
  "name": "systems-api",
  "version": "2.0.0-rc.1",
  "description": "SYSTEMS. API — self-hosted deployment engine (Node.js + Fastify)",
  "license": "MIT",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test": "node --test",
    "test:coverage": "node --test --experimental-test-coverage --test-coverage-exclude=\"src/routes/**\" --test-coverage-exclude=\"src/services/**\" --test-coverage-exclude=\"src/db/**\" --test-coverage-exclude=\"src/index.js\" --test-coverage-exclude=\"src/app.js\" --test-coverage-lines=70 --test-coverage-functions=65 --test-coverage-branches=55",
    "lint": "eslint src test"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@fastify/cors": "^9",
    "@fastify/jwt": "^8",
    "@fastify/multipart": "^8",
    "@fastify/rate-limit": "^9",
    "@fastify/websocket": "^8",
    "bcrypt": "^6",
    "better-sqlite3": "^9",
    "dockerode": "^4",
    "fastify": "^4",
    "unzipper": "^0.12",
    "uuid": "^14"
  },
  "optionalDependencies": {
    "pg": "^8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.5.0",
    "globals": "^17.6.0"
  }
}

{
  "name": "systems-api",
  "version": "2.0.0-rc.1",
  "description": "SYSTEMS. API — self-hosted deployment engine (Node.js + Fastify)",
  "license": "PolyForm-Noncommercial-1.0.0",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "dev:local": "node --env-file=../.env --watch src/index.js",
    "test": "node --test --test-concurrency=1",
    "test:e2e": "node --test test/deploy.e2e.test.js",
    "test:coverage": "node --test --test-concurrency=1 --experimental-test-coverage --test-coverage-exclude=\"src/routes/**\" --test-coverage-exclude=\"src/services/**\" --test-coverage-exclude=\"src/db/**\" --test-coverage-exclude=\"src/index.js\" --test-coverage-exclude=\"src/app.js\" --test-coverage-lines=70 --test-coverage-functions=65 --test-coverage-branches=55",
    "lint": "eslint src test scripts",
    "migrate:postgres": "node scripts/migrate-sqlite-to-postgres.js",
    "prisma:generate": "dotenv -e ../.env -- prisma generate --schema=prisma/schema.prisma",
    "prisma:migrate": "dotenv -e ../.env -- prisma migrate dev --schema=prisma/schema.prisma",
    "prisma:deploy": "dotenv -e ../.env -- prisma migrate deploy --schema=prisma/schema.prisma",
    "prisma:studio": "dotenv -e ../.env -- prisma studio --schema=prisma/schema.prisma"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^10.1.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^11.0.0",
    "@fastify/websocket": "^11.2.0",
    "@prisma/client": "^6.19.3",
    "bcrypt": "^6",
    "dockerode": "^4",
    "fastify": "^5.8.5",
    "pg": "^8",
    "unzipper": "^0.12",
    "uuid": "^14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "prisma": "^7.8.0"
  }
}

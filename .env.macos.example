# Copy to .env.macos only for manual setup. The setup script generates secrets.
SYSTEMS_HTTP_PORT=8080
SYSTEMS_MAC_DATA_DIR=/Users/your-user/Library/Application Support/SYSTEMS
SYSTEMS_MAC_NGINX_CONF_DIR=/Users/your-user/Library/Application Support/SYSTEMS/nginx/conf.d
JWT_SECRET=replace-with-at-least-32-random-characters
ENV_SECRET=replace-with-at-least-32-random-characters
SYSTEMS_ATTESTATION_SECRET=replace-with-at-least-32-random-characters
ADMIN_USERS=admin:replace-with-a-strong-password
RECONCILE_INTERVAL_SEC=30

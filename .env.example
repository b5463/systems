# ============================================================
# SYSTEMS. by Acronym — environment configuration (Windows-first)
# ============================================================
# Copy to .env and fill in real values. NEVER commit a real .env.
# Production target is a WINDOWS machine/VPS running Docker Desktop
# (Linux containers via WSL2). Linux is a secondary/dev target only.
#
# Status tags:
#   [ACTIVE]   read by the current backend
#   [PLANNED]  reserved for a future migration; not consumed today
# Paths use Windows defaults; on Linux/dev override with POSIX paths.
# ------------------------------------------------------------

# ---- Server port -------------------------------------------
PORT=3000

# ---- Domains & routing -------------------------------------
BASE_DOMAIN=acronym.sk
DASHBOARD_DOMAIN=systems.acronym.sk
WILDCARD_DOMAIN=*.acronym.sk
PUBLIC_SCHEME=https
# Set true when running the API directly with Vite/localhost and no DNS/TLS
# proxy. BASE_DOMAIN=localhost/127.0.0.1 also enables this automatically. Health
# probes then always use http://<SYSTEMS_APP_UPSTREAM_HOST>:<system-port>.
LOCAL_MODE=false
SERVER_IP=YOUR_SERVER_IP
REVERSE_PROXY=caddy
# Private upstream used only by generated proxy routes for encrypted route
# attestations. Must not be publicly reachable.
SYSTEMS_API_INTERNAL_UPSTREAM=host.docker.internal:3000
# Hostname Caddy/the API uses to reach mapped application host ports. Use
# 127.0.0.1 when Caddy and the API run directly as Windows services (not in
# Docker). Use host.docker.internal when they run inside Docker containers.
SYSTEMS_APP_UPSTREAM_HOST=host.docker.internal
# Optional dedicated 32+ character master secret. If blank, ENV_SECRET is used
# with domain-separated key derivation. Prefer a distinct production secret.
SYSTEMS_ATTESTATION_SECRET=

# ---- Windows data locations (C:\ProgramData\SYSTEMS) -------
SYSTEMS_DATA_DIR=C:\ProgramData\SYSTEMS
DEPLOYMENTS_DIR=C:\ProgramData\SYSTEMS\releases
UPLOADS_DIR=C:\ProgramData\SYSTEMS\uploads
LOGS_DIR=C:\ProgramData\SYSTEMS\logs
BACKUP_DIR=C:\ProgramData\SYSTEMS\backups

# ---- Caddy (Windows) ---------------------------------------
# Main Caddyfile imports per-system route files from CADDY_SYSTEMS_DIR:
#   import C:\ProgramData\SYSTEMS\caddy\systems.d\*.caddy
CADDY_CONFIG_PATH=C:\ProgramData\SYSTEMS\caddy\Caddyfile
CADDY_SYSTEMS_DIR=C:\ProgramData\SYSTEMS\caddy\systems.d

# ---- PostgreSQL (control-plane database) -------------------
# SYSTEMS. uses PostgreSQL (via Prisma ORM) for the control-plane database.
# DATABASE_URL is required — Prisma reads it to connect.
#   Generate a strong password:
#     node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
#   Then construct the URL:
#     postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# When running Postgres via Docker alongside the API, the host is the container
# name (e.g. systems-postgres). When Postgres runs as a native Windows service,
# use localhost or 127.0.0.1.
DATABASE_URL=postgresql://systems:CHANGE_ME@systems-postgres:5432/systems

# POSTGRES_HOST enables the Server dashboard health indicator for Postgres.
# Set it to the hostname where the control-plane Postgres is reachable from
# the API process (container name, localhost, or IP).
POSTGRES_HOST=systems-postgres
POSTGRES_PORT=5432
POSTGRES_DB=systems
POSTGRES_USER=systems
POSTGRES_PASSWORD=CHANGE_ME

# ---- Legacy SQLite migration (one-time) --------------------
# These are only used by api/scripts/migrate-sqlite-to-postgres.js to copy
# data from a pre-v3 SQLite database into PostgreSQL. Not needed for fresh
# installs. See docs/POSTGRES_PRISMA_MIGRATION.md.
CONTROL_PLANE_POSTGRES_URL=
CONTROL_PLANE_POSTGRES_SCHEMA=systems_import
CONTROL_PLANE_SQLITE_PATH=

# ---- Limits & retention ------------------------------------
UPLOAD_MAX_MB=100
V2_UPLOAD_MAX_MB=2048
BUILD_TIMEOUT_SECONDS=600
MAX_CONCURRENT_BUILDS=1
BUILD_CPU_LIMIT=1
BUILD_MEMORY_MB=1024
# These safe defaults can also be overridden from Admin → Platform settings.
RELEASE_RETENTION_DEFAULT=3
STATS_RETENTION_HOURS=168
BACKUP_OVERDUE_HOURS=168
ALERT_MEMORY_PERCENT=90
ALERT_CPU_PERCENT=90
ALERT_HEALTH_FAILURES=3

# ---- Docker ------------------------------------------------
DOCKER_NETWORK=systems

# ---- First admin -------------------------------------------
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ---- Per-deployed-system resource defaults [ACTIVE] --------
# Applied to every deployed container so one project cannot eat the host.
DEFAULT_CONTAINER_CPU_LIMIT=0.5
DEFAULT_CONTAINER_MEMORY_MB=512
DEFAULT_CONTAINER_PIDS_LIMIT=256
DEFAULT_CONTAINER_RESTART_POLICY=unless-stopped
DEFAULT_CONTAINER_LOG_MAX_SIZE=10m
DEFAULT_CONTAINER_LOG_MAX_FILE=3
DEFAULT_CONTAINER_DISK_WARN_MB=1024

# ---- Backups -----------------------------------------------
BACKUP_RETENTION_DAYS=14
BACKUP_INCLUDE_LOGS=false
BACKUP_INCLUDE_UPLOADS=false
BACKUP_REQUIRE_CONFIRMATION=true

# ---- V2 feature flags (risky features OFF by default) ------
# [PLANNED/EXPERIMENTAL] Enable only after reading the matching docs/*.md and
# validating on the Windows host. See docs/SECURITY.md (V2 review).
ENABLE_DOCKERFILE_MODE=false
ENABLE_SHELL_CONSOLE=false
ENABLE_DB_PROVISIONING=false
DB_MODE=shared
ENABLE_GITHUB_DEPLOYS=false
ENABLE_NOTIFICATIONS=false
ENABLE_LARGE_UPLOADS=false
GITHUB_WEBHOOK_SECRET=
GITHUB_TOKEN=
POSTGRES_ADMIN_URL=
NOTIFY_WEBHOOK_URL=
NOTIFY_FORMAT=generic

# ---- V3 feature flags (OFF by default) --------------------
ENABLE_API_TOKENS=false
ENABLE_SECRETS_MANAGEMENT=false
ENABLE_PREVIEW_ENVIRONMENTS=false
ENABLE_MULTI_NODE=false
ENABLE_OBJECT_STORAGE_BACKUPS=false
ENABLE_BUILD_CACHE=false

# ---- V3: Preview environments -----------------------------
PREVIEW_TTL_HOURS=72
PREVIEW_CLEANUP_INTERVAL_SEC=300

# ---- V3: Multi-node ---------------------------------------
NODE_HEALTH_INTERVAL_SEC=60

# ---- V3: Object storage (S3-compatible) -------------------
S3_ENDPOINT=
S3_BUCKET=systems-backups
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ---- Operations (active by default) ------------------------
# Reconcile DB status against real container state on this interval (seconds).
# Set to 0 to disable.
RECONCILE_INTERVAL_SEC=30
# Periodic backup (pg_dump + Caddy routes). A manual backup is always available
# via the dashboard / POST /api/server/backup; this only controls the scheduler.
ENABLE_BACKUP_SCHEDULER=false
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION=14
CADDY_ROUTES_DIR=
# Audit log is a tamper-evident SHA-256 hash chain. Prune entries older than N
# days on boot + daily (the chain stays verifiable from the first retained row).
# 0 = keep everything. Verify via GET /api/audit/verify.
AUDIT_RETENTION_DAYS=0

# ============================================================
# SECRETS (required to run)
# ============================================================

# Signing key for admin session tokens. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string
# Optional distinct HMAC key for CSRF tokens. If blank, JWT_SECRET is used.
CSRF_SECRET=
# Session is revalidated server-side; refresh cannot exceed the absolute lifetime.
SESSION_IDLE_MINUTES=720
SESSION_ABSOLUTE_HOURS=168

# First admins, "user:password,user2:password2" (two admins max,
# no public signup). ADMIN_EMAIL/ADMIN_PASSWORD are planned and not read today.
ADMIN_USERS=admin:replace-with-a-unique-15-character-or-longer-passphrase

# CORS locked to the dashboard origin.
CORS_ORIGIN=https://systems.acronym.sk

# AES-256-GCM key for encrypting per-system env vars at rest.
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENV_SECRET=change-me-to-64-hex-chars-random-value-here-000000000000000000

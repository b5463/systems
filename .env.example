# ============================================================
# SYSTEMS. by Acronym — environment configuration (V1.1)
# ============================================================
# Copy to .env and fill in real values. NEVER commit a real .env.
# A Windows-first version of this file will be locked in before V1.2.
#
# Variables are grouped by status:
#   [ACTIVE]   read by the V1.1 backend today
#   [PLANNED]  documented targets, not yet wired (V1.2) — safe to leave blank
# ------------------------------------------------------------

# ---- Domains & routing -------------------------------------
# [ACTIVE] Used by the dashboard build (as VITE_* below) and docs.
BASE_DOMAIN=acronym.sk
DASHBOARD_DOMAIN=systems.acronym.sk
WILDCARD_DOMAIN=*.acronym.sk
PUBLIC_SCHEME=https
SERVER_IP=YOUR_SERVER_IP
# [PLANNED] V1.2 swaps the reverse proxy from nginx to caddy.
REVERSE_PROXY=caddy

# ---- Internal database -------------------------------------
# [PLANNED] V1.1 ships SQLite (file at api ./data/platform.db). The settings
# below are the Postgres migration target for V1.2 — leaving them blank does
# NOT break V1.1.
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=systems
POSTGRES_USER=systems
POSTGRES_PASSWORD=

# ---- Limits & retention ------------------------------------
# [ACTIVE in V1.2 settings; surfaced read-only in V1.1 Admin]
UPLOAD_MAX_MB=100
V2_UPLOAD_MAX_MB=2048
BUILD_TIMEOUT_SECONDS=600
RELEASE_RETENTION_DEFAULT=3

# ---- Docker ------------------------------------------------
# [ACTIVE] Deployed containers run on an isolated bridge network.
DOCKER_NETWORK=systems

# ---- First admin -------------------------------------------
# [PLANNED] V1.2 bootstraps the first admin from ADMIN_EMAIL/ADMIN_PASSWORD
# (or a setup command). V1.1 still uses ADMIN_USERS below.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ============================================================
# CURRENTLY-WIRED V1.1 SECRETS (required to run today)
# ============================================================

# [ACTIVE] Signing key for admin session tokens. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# [ACTIVE] First admins, format "user:password,user2:password2".
# Two admins max in V1. No public signup. Superseded by ADMIN_EMAIL in V1.2.
ADMIN_USERS=admin:change-this-password

# [ACTIVE] CORS is locked to the dashboard origin.
CORS_ORIGIN=https://systems.acronym.sk

# [ACTIVE] AES-256-GCM key for encrypting per-system env vars at rest.
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENV_SECRET=change-me-to-64-hex-chars-random-value-here-000000000000000000

# [ACTIVE today, removed in V1.2] Email for nginx/Let's Encrypt certs.
# V1.2 delegates TLS to Caddy's automatic HTTPS.
CERTBOT_EMAIL=admin@acronym.sk

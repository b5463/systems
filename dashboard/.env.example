# SYSTEMS. dashboard — build-time configuration
# Copy to dashboard/.env. These are baked into the static build by Vite, so
# they must NOT contain secrets — they are public once built.

# Domain the deployed systems live under (used for URL previews/links).
VITE_BASE_DOMAIN=acronym.sk

# Scheme shown in public URL previews.
VITE_PUBLIC_SCHEME=https

# Read-only values surfaced in the Admin screen (mirror the API .env).
VITE_UPLOAD_MAX_MB=100
VITE_RELEASE_RETENTION=3
